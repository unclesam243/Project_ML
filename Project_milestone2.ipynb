        "# ============================================================\n",
        "# STEP 9 — ABLATION: MLP Depth\n",
        "# ============================================================\n",
        "print(\"\\n\" + \"=\"*55)\n",
        "print(\"ABLATION: MLP Depth (1 vs 2 vs 3 hidden layers)\")\n",
        "print(\"=\"*55)\n",
        "\n",
        "configs = {\n",
        "    '1 Layer  (64)':       [64],\n",
