        "}\n",
        "\n",
        "def build_mlp(layers, input_dim):\n",
        "    blocks = []\n",
        "    in_dim = input_dim\n",
        "    for out_dim in layers:\n",
        "        blocks += [nn.Linear(in_dim, out_dim), nn.BatchNorm1d(out_dim),\n",
        "                   nn.ReLU(), nn.Dropout(0.3)]\n",
        "        in_dim = out_dim\n",
        "    blocks.append(nn.Linear(in_dim, 1))\n",
        "    return nn.Sequential(*blocks)\n",
        "\n",
        "ablation_results = []\n",
        "for name, layers in configs.items():\n",
        "    auprcs = []\n",
        "    for seed in SEEDS:\n",
        "        torch.manual_seed(seed)\n",
        "        m = build_mlp(layers, X_temp_train.shape[1]).to(device)\n",
        "        opt = torch.optim.Adam(m.parameters(), lr=1e-3)\n",
        "        crit = nn.BCEWithLogitsLoss(pos_weight=pos_weight)\n",
        "        dl = DataLoader(TensorDataset(Xt_tr, yt_tr), batch_size=256, shuffle=True)\n",
        "        best, patience_c = 0, 0\n",
        "        for _ in range(50):\n",
        "            m.train()\n",
        "            for xb, yb in dl:\n",
        "                opt.zero_grad()\n",
        "                crit(m(xb.to(device)), yb.to(device)).backward()\n",
        "                opt.step()\n",
        "            m.eval()\n",
        "            with torch.no_grad():\n",
