        "# ============================================================\n",
        "# STEP 3 — Data Preprocessing\n",
        "# ============================================================\n",
        "\n",
        "# Handle missing values before further processing\n",
        "df.dropna(inplace=True)\n",
        "\n",
        "X = df.drop(columns=['Class'])\n",
        "y = df['Class']\n",
        "\n",
        "# Sort by Time and split chronologically: 60% train / 20% val / 20% test\n",
        "# This avoids leaking information\n",
        "df_sorted = df.sort_values('Time').reset_index(drop=True)\n",
        "n = len(df_sorted)\n",
        "train_end = int(n * 0.60)\n",
        "val_end   = int(n * 0.80)\n",
        "\n",
        "X_temp_train = df_sorted.iloc[:train_end].drop(columns=['Class'])\n",
        "y_temp_train = df_sorted.iloc[:train_end]['Class']\n",
        "X_temp_val   = df_sorted.iloc[train_end:val_end].drop(columns=['Class'])\n",
        "y_temp_val   = df_sorted.iloc[train_end:val_end]['Class']\n",
        "X_temp_test  = df_sorted.iloc[val_end:].drop(columns=['Class'])\n",
        "y_temp_test  = df_sorted.iloc[val_end:]['Class']\n",
        "\n",
        "print(f\"\\nTemporal Split:\")\n",
        "print(f\"  Train: {len(X_temp_train):,} | Fraud: {y_temp_train.sum()}\")\n",
        "print(f\"  Val:   {len(X_temp_val):,}   | Fraud: {y_temp_val.sum()}\")\n",
        "print(f\"  Test:  {len(X_temp_test):,}  | Fraud: {y_temp_test.sum()}\")\n",
        "\n",
        "# RobustScaler uses median and IQR — more resilient to Amount's extreme outliers\n",
        "# V1-V28 are already PCA-transformed (zero mean, unit variance) — do NOT rescale\n",
        "scaler = RobustScaler()\n",
        "for X_split in [X_temp_train, X_temp_val, X_temp_test]:\n",
        "    X_split[['Time','Amount']] = scaler.fit_transform(\n",
        "        X_temp_train[['Time','Amount']]  # always fit on train only\n",
        "    ) if X_split is X_temp_train else scaler.transform(X_split[['Time','Amount']])\n",
        "\n",
        "#  Class weights (w1/w0 = 578)\n",
        "# w1 = Nlegit/Ntotal, w0 = Nfraud/Ntotal as specified in proposal\n",
        "n_legit = (y_temp_train == 0).sum()\n",
        "n_fraud = (y_temp_train == 1).sum()\n",
        "w1 = n_legit / len(y_temp_train)   # weight for fraud class\n",
        "w0 = n_fraud / len(y_temp_train)   # weight for legit class\n",
        "print(f\"\\nClass weights → Legit (w0): {w0:.6f} | Fraud (w1): {w1:.6f}\")\n",
        "print(f\"Fraud/Legit weight ratio: {w1/w0:.1f}x\")"
      ],
