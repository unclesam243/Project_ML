      "cell_type": "code",
      "source": [
        "# ============================================================\n",
        "# STEP 8 — MLP (Deep Learning) with 5-Seed Evaluation\n",
        "# ============================================================\n",
        "print(\"\\n\" + \"=\"*55)\n",
        "print(\"MLP (Deep Learning) — 5 Seeds\")\n",
        "print(\"=\"*55)\n",
        "\n",
        "device = torch.device('cuda' if torch.cuda.is_available() else 'cpu')\n",
        "print(f\"Device: {device}\")\n",
        "\n",
        "# MLP Architecture with seed: (30->64->32->1)\n",
        "class FraudMLP(nn.Module):\n",
        "    def __init__(self, input_dim):\n",
        "        super().__init__()\n",
        "        self.net = nn.Sequential(\n",
        "            nn.Linear(input_dim, 64),\n",
        "            nn.BatchNorm1d(64),\n",
        "            nn.ReLU(),\n",
        "            nn.Dropout(0.3),\n",
        "            nn.Linear(64, 32),\n",
        "            nn.BatchNorm1d(32),\n",
        "            nn.ReLU(),\n",
        "            nn.Dropout(0.3),\n",
        "            nn.Linear(32, 1)\n",
        "\n",
        "        )\n",
        "    def forward(self, x):\n",
        "        return self.net(x)\n",
        "\n",
        "# Convert splits to tensors\n",
        "def to_tensor(X, y):\n",
        "    return (torch.tensor(X.values, dtype=torch.float32),\n",
        "            torch.tensor(y.values, dtype=torch.float32).unsqueeze(1))\n",
        "\n",
        "Xt_tr, yt_tr = to_tensor(X_temp_train, y_temp_train)\n",
        "Xt_vl, yt_vl = to_tensor(X_temp_val,   y_temp_val)\n",
        "Xt_te, yt_te = to_tensor(X_temp_test,  y_temp_test)\n",
        "\n",
        "# pos_weight encodes the w1/w0 ratio for weighted BCE\n",
        "# L = -[w1*y*log(p) + w0*(1-y)*log(1-p)]\n",
        "pos_weight = torch.tensor([w1 / w0]).to(device)\n",
        "\n",
        "seed_results, seed_probs = [], []\n",
        "\n",
        "for seed in SEEDS:\n",
        "    torch.manual_seed(seed)\n",
        "    np.random.seed(seed)\n",
        "\n",
        "    model = FraudMLP(input_dim=X_temp_train.shape[1]).to(device)\n",
        "    criterion = nn.BCEWithLogitsLoss(pos_weight=pos_weight)\n",
        "    optimizer = torch.optim.Adam(model.parameters(), lr=1e-3)\n",
        "\n",
        "    train_ds = TensorDataset(Xt_tr, yt_tr)\n",
        "    train_dl = DataLoader(train_ds, batch_size=256, shuffle=True)\n",
        "\n",
        "    best_f1, best_thresh, patience_counter = 0, 0.5, 0\n",
        "    best_state = None\n",
        "\n",
        "    for epoch in range(50):\n",
        "        model.train()\n",
        "        for X_b, y_b in train_dl:\n",
        "            X_b, y_b = X_b.to(device), y_b.to(device)\n",
        "            optimizer.zero_grad()\n",
        "            nn.BCEWithLogitsLoss(pos_weight=pos_weight)(model(X_b), y_b).backward()\n",
        "            optimizer.step()\n",
        "\n",
        "        # Evaluate on val set to find optimal threshold\n",
        "        model.eval()\n",
        "        with torch.no_grad():\n",
        "            val_logits = model(Xt_vl.to(device)).cpu().numpy().flatten()\n",
        "            val_probs  = torch.sigmoid(torch.tensor(val_logits)).numpy()\n",
        "\n",
        "        thresh = find_optimal_threshold(y_temp_val, val_probs)\n",
        "        val_f1 = f1_score(y_temp_val, (val_probs >= thresh).astype(int))\n",
        "\n",
        "        if val_f1 > best_f1:\n",
        "            best_f1, best_thresh = val_f1, thresh\n",
        "            best_state = {k: v.clone() for k, v in model.state_dict().items()}\n",
        "            patience_counter = 0\n",
        "        else:\n",
        "            patience_counter += 1\n",
        "            if patience_counter >= 5:\n",
        "                break\n",
        "\n",
        "    # Evaluate best model on test set\n",
        "    model.load_state_dict(best_state)\n",
        "    model.eval()\n",
        "    with torch.no_grad():\n",
        "        test_logits = model(Xt_te.to(device)).cpu().numpy().flatten()\n",
        "        test_probs  = torch.sigmoid(torch.tensor(test_logits)).numpy()\n",
        "\n",
        "    res = evaluate(f'MLP (seed={seed})', y_temp_test, test_probs, best_thresh)\n",
        "    seed_results.append(res)\n",
        "    seed_probs.append(test_probs)\n",
        "    print(f\"  Seed {seed}: AUPRC={res['AUPRC']:.4f} | F1={res['F1']:.4f} | Thresh={best_thresh:.3f}\")\n",
        "\n",
        "# Aggregate mean ± std across seeds\n",
        "mlp_df = pd.DataFrame(seed_results)\n",
        "print(f\"\\nMLP Mean ± Std across {len(SEEDS)} seeds:\")\n",
        "for col in ['AUPRC','AUROC','F1','Precision','Recall']:\n",
        "    print(f\"  {col:10s}: {mlp_df[col].mean():.4f} ± {mlp_df[col].std():.4f}\")\n",
        "\n",
        "# Use mean probabilities across seeds for final plots\n",
        "mlp_probs_mean = np.mean(seed_probs, axis=0)\n",
        "mlp_thresh_final = find_optimal_threshold(y_temp_val,\n",
        "    np.mean([torch.sigmoid(torch.tensor(\n",
        "        FraudMLP(X_temp_train.shape[1]).to(device)(Xt_vl.to(device))\n",
        "        .detach().cpu().numpy().flatten())).numpy() for _ in range(1)], axis=0))\n",
        "\n"
      ],
